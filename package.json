  "scripts": {
    "dev-debug": "cross-env NODE_ENV=development node debug/store/redux.js",
    "dev-mock": "cross-env USE_MOCKS=true vite",
    "dev-init": "cross-env INIT_STORE=true vite",
    "dev": "vite",
    "eslint": "npx eslint --fix src/ && npx eslint 'src/**'",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "start": "cross-env NODE_ENV=production node server/serve.js",
    "serve": "cross-env NODE_ENV=production node server/serve.js",
    "cypress-dev-server": "cross-env NODE_ENV=cypressserver vite",
    "server": "cross-env NODE_ENV=$npm_config_nodeenv node server/serve.js",
    "dev-https": "cross-env PM_HTTPS=true vite",
    "start-https": "cross-env NODE_ENV=production PM_HTTPS=true node server/serve.js",
    "server-https": "cross-env NODE_ENV=$npm_config_nodeenv PM_HTTPS=true node server/serve.js",
    "start-local": "cross-env LOCAL_ENV=1 NODE_ENV=production node server/serve.js",
    "build": "node server/aws_helper_prebuild.js && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test-circle-ci": "jest --runInBand",
    "test-watch": "jest --watchAll",
    "test-coverage": "cross-env node testServer/index.js",
    "cypress-run-ally": "NODE_ENV=development cypress open --component --browser chrome --env CYPRESS_ENV=local,ABTESTBAND=$npm_config_ab,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false,watchForFileChanges=true",
    "cypress-run-ally-headless": "cypress install && NODE_ENV=development cypress run --component --browser chrome --headless --spec 'cypress/component/A11yTests/**/index.js' --env CYPRESS_ENV=local,ABTESTBAND=$npm_config_ab,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false",
    "cypress-open": "NODE_ENV=development cypress open --browser chrome --env CYPRESS_ENV=$npm_config_cypress_config,JIRA_TICKET=$npm_config_jira,ABTESTBAND=$npm_config_ab,TENANT_CODE=pm",
    "cypress-run-partiale2e": "cypress install --force && SPEC=${npm_config_spec:-cypress/e2e/partialE2E/**/index.{js,ts}} && TENANT_CODE=${npm_config_tenant_code:-pm} && echo \"Running Cypress specs: $SPEC (tenant: $TENANT_CODE)\" && NODE_ENV=development cypress run --e2e --browser chrome --headless --spec \"$SPEC\" --env CYPRESS_ENV=$npm_config_cypress_config,TENANT_CODE=$TENANT_CODE,JIRA_TICKET=$npm_config_jira --config pageLoadTimeout=300000,video=false,retries=2",
    "cypress-run-components-no-percy": "cypress install --force && NODE_ENV=development cypress run --component --spec 'cypress/component/ComponentTests/**/*' --env CYPRESS_ENV=local,TENANT_CODE=pm --config video=false",
    "cypress-run-components": "cypress install --force && NODE_ENV=development percy exec -- cypress run --component --spec 'cypress/component/ComponentTests/**/*' --env CYPRESS_ENV=local,TENANT_CODE=pm --config video=false",
    "cypress-open-components": "NODE_ENV=development cypress open --browser chrome --component --env CYPRESS_ENV=$npm_config_cypress_config,ABTESTBAND=$npm_config_ab,TENANT_CODE=${npm_config_tenant_code:-pm}",
    "cypress-run-components-single": "NODE_ENV=development cypress run --component --env CYPRESS_ENV=local,TENANT_CODE=pm --config video=false --spec \"cypress/component/$npm_config_test\"",
    "cypress-run": "NODE_ENV=development cypress run --e2e --browser chrome --headless --config pageLoadTimeout=300000,video=false",
    "cypress-record": "NODE_ENV=development cypress run --e2e --env CYPRESS_ENV=$npm_config_cypress_config --headless --browser chrome --config pageLoadTimeout=200000 --record",
    "cypress-run-internal-tool-tests-joint": "NODE_ENV=development cypress run --e2e --browser chrome --headless --spec 'cypress/e2e/NewJoint/index.{js,ts}' --env CYPRESS_ENV=$npm_config_cypress_config,TENANT_CODE=$npm_config_tenant_code --config pageLoadTimeout=300000,video=false",
    "cypress-run-internal-tool-tests-all": "NODE_ENV=development cypress run --e2e --browser chrome --headless --spec 'cypress/e2e/InternalToolTesting/**/index.{js,ts}' --env CYPRESS_ENV=$npm_config_cypress_config,TENANT_CODE=$npm_config_tenant_code,ABTESTBAND=$npm_config_ab --config pageLoadTimeout=300000,video=false",
    "cypress-run-internal-tool-tests-single": "NODE_ENV=development cypress run --e2e --browser chrome --headless --spec \"cypress/e2e/InternalToolTesting/TestCase$npm_config_test/index.{js,ts}\" --env CYPRESS_ENV=$npm_config_cypress_config,TENANT_CODE=$npm_config_tenant_code,ABTESTBAND=$npm_config_ab,JIRA_TICKET=$npm_config_jira --config pageLoadTimeout=300000,video=false",
    "cypress-component-tests-bucket1": "NODE_ENV=development cypress run --component --browser chrome --headless --spec \"cypress/component/ComponentTests/[A-L]*.{js,tsx},cypress/component/ComponentTests/[a-l]*.{js,tsx}\" --env CYPRESS_ENV=local,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false",
    "cypress-component-tests-bucket2": "NODE_ENV=development cypress run --component --browser chrome --headless --spec \"cypress/component/ComponentTests/[M-Z]*.{js,tsx},cypress/component/ComponentTests/[m-z]*.{js,tsx},cypress/component/ComponentTests/HDPlanTest/**/*\" --env CYPRESS_ENV=local,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false",
    "cypress-a11y-tests-bucket1": "NODE_ENV=development cypress run --component --browser chrome --headless --spec \"cypress/component/A11yTests/[A-L]*/**/*.{js,tsx},cypress/component/A11yTests/[a-l]*/**/*.{js,tsx}\" --env CYPRESS_ENV=local,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false",
    "cypress-a11y-tests-bucket2": "NODE_ENV=development cypress run --component --browser chrome --headless --spec \"cypress/component/A11yTests/[M-Z]*/**/*.{js,tsx},cypress/component/A11yTests/[m-z]*/**/*.{js,tsx}\" --env CYPRESS_ENV=local,TENANT_CODE=pm --config pageLoadTimeout=300000,video=false",
    "storybook": "cross-env STORYBOOK_ENV=storybook start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "deploy-storybook": "storybook-to-aws-s3 --bucket-path=policyme-global-libjs-layout-internal/life",
    "extract": "formatjs extract --ignore='**/*.d.{js,ts}' --out-file lang/en-new.json --id-interpolation-pattern '[sha512:contenthash:base64:6]' \"src/**/*.{js,jsx,tsx}\" --format simple --flatten",
    "extract-merge": "npm run extract && node ./mergeLangJson.js",
    "compile-en": "formatjs compile \"lang/en_CA.json\" \"lang/legal_en_CA.json\" --ast --out-file compiled-lang/en_CA.json --format simple",
    "compile-fr": "formatjs compile \"lang/fr_CA.json\" \"lang/legal_fr_CA.json\" --ast --out-file compiled-lang/fr_CA.json --format simple",
    "generate-lang-tests": "node ./automaticLangTests.js",
    "type-check": "tsc --noEmit --project tsconfig.check.json",
    "type-check-watch": "tsc --noEmit --watch --project tsconfig.check.json",
    "eslint-check": "eslint .",
    "eslint-report": "npm run --silent eslint-check -- --format json > eslint-report.json",
    "eslint-ignore-list": "npm run eslint-report && node node_modules/@policyme/global-libjs-utils/create_eslint_ignore_list.js",
    "auto-ignore": "node node_modules/@policyme/global-libjs-utils/apply_eslint_ignores.js",
    "eslint-ratchet": "node node_modules/@policyme/global-libjs-utils/eslint_ignore_ratchet.js"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "echo \"pre commit hook executing\""
    ],
    "*.{json,md,yml,yaml}": [
      "echo \"pre commit hook executing\""
    ]
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "babel": {
    "presets": [
      "react-app",
      [
        "@babel/preset-typescript",
        {
          "isTSX": true,
          "allExtensions": true
        }
      ],
      "@emotion/babel-preset-css-prop"
    ],
    "plugins": [
      [
        "formatjs",
        {
          "idInterpolationPattern": "[sha512:contenthash:base64:6]",
          "ast": true
        }
      ]
    ],
    "env": {
      "production": {
        "plugins": [
          [
            "formatjs",
            {
              "idInterpolationPattern": "[sha512:contenthash:base64:6]",
              "ast": true
            }
          ]
        ]
      },
      "development": {
        "plugins": [
          [
            "formatjs",
            {
              "idInterpolationPattern": "[sha512:contenthash:base64:6]",
              "ast": true
            }
          ]
        ]
      },
      "test": {
        "plugins": [
          "dynamic-import-node",
          [
            "formatjs",
            {
              "idInterpolationPattern": "[sha512:contenthash:base64:6]",
              "ast": true
            }
          ]
        ]
      },
      "cypressserver": {
        "plugins": [
          [
            "formatjs",
            {
              "idInterpolationPattern": "[sha512:contenthash:base64:6]",
              "ast": true
            }
          ]
        ]
      }
    }
  }
}
